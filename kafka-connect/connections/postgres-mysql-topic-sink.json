{
  "name": "postgres-mysql-topic-sink",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://${PG_HOST}:${PG_PORT}/${PG_DB}",
    "dialect.name": "PostgreSqlDatabaseDialect",
    "connection.user": "${PG_USER}",
    "connection.password": "${PG_PASSWORD}",
    "topics.regex": "mysql_series\\.series\\..*",

    "table.name.format": "kafka_sink.${topic}",
    "insert.mode": "upsert",
    "delete.enabled": "true",

    "auto.create": "true",
    "auto.evolve": "true",

    "pk.mode": "record_key",
    "pk.fields": "id",

    "transforms": "unwrap,addPrefix",
    "transforms.addPrefix.type":"org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.addPrefix.regex":"mysql_series\\.series\\.(.*)",
    "transforms.addPrefix.replacement":"mysql_series_$1",

    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.unwrap.delete.handling.mode": "rewrite"
  }
}
